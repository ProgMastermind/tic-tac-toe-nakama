# Copy this file to `.env` and edit values for your environment. The .env
# file is gitignored; only this example and any deployment-specific
# configurations belong in source control.

# Nakama host and port. For the local docker compose stack on the same
# machine, use 127.0.0.1:7350 and disable SSL.
VITE_NAKAMA_HOST=127.0.0.1
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_USE_SSL=false

# The server key is the shared secret configured in local.yml /
# prod.yml under runtime.http_key. Must match the value the server
# was started with. Rotate alongside deployments.
VITE_NAKAMA_SERVER_KEY=defaultkey
