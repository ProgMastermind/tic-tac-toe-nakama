# Template for Vercel production environment variables.
#
# Do NOT commit a real .env.production — set these values in the Vercel
# dashboard (Settings → Environment Variables, scope: Production). Vercel
# will inject them at build time, Vite will inline the VITE_* ones into
# the client bundle.
#
# Match VITE_NAKAMA_SERVER_KEY to the NAKAMA_SERVER_KEY you set via
# `heroku config:set` on the server — they MUST be the same string.

# Heroku app hostname (no scheme, no path). Example: tic-tac-toe-nakama.herokuapp.com
VITE_NAKAMA_HOST=<your-app>.herokuapp.com

# Heroku routes HTTPS on 443; the Nakama JS SDK uses this for both the
# REST calls and the WebSocket upgrade.
VITE_NAKAMA_PORT=443
VITE_NAKAMA_USE_SSL=true

# Shared socket.server_key. Generate once with `openssl rand -hex 24`
# and set the same value via `heroku config:set NAKAMA_SERVER_KEY=...`.
VITE_NAKAMA_SERVER_KEY=<paste-NAKAMA_SERVER_KEY-here>
